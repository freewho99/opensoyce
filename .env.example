# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GITHUB_TOKEN: Optional GitHub Personal Access Token to increase API rate limits (60 -> 5000 req/hr).
GITHUB_TOKEN=your_github_personal_access_token_here

# Guard early-access waitlist (private GitHub repo used as zero-infra storage).
# If unset, /api/early-access still returns success but submissions only land in logs.
EARLY_ACCESS_REPO_OWNER=
EARLY_ACCESS_REPO_NAME=

# OpenSoyce Guard GitHub App
# See docs/guard-app-setup.md for full setup walkthrough.
GUARD_APP_ID=
GUARD_APP_PRIVATE_KEY_BASE64=
GUARD_WEBHOOK_SECRET=

# GUARD_FORCE_RESCORE: Operator escape hatch for the durable check-run dedupe.
# When set to "1", guard-webhook.js skips the "already processed this head SHA"
# early-return and re-scores the PR, overwriting the prior verdict comment.
# Leave unset (or any value other than "1") for normal idempotent behavior.
GUARD_FORCE_RESCORE=

# Supabase project (Sprint+3 exceptions storage)
# See docs/supabase-setup.md
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenSoyce Guard dashboard session HMAC key (Sprint+3 exceptions dashboard).
# Used to sign + verify the osg_session token issued after the dashboard
# OAuth round-trip. Long random string (e.g. `openssl rand -hex 32`).
# PR 1 only verifies tokens — minting ships with the PR 3 OAuth callback.
OPENSOYCE_DASHBOARD_SECRET=
